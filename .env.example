# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# =========================
# SYSTEM ADMIN SECURITY
# =========================

# VITE_ADMIN_USERNAME: The username of the administrator account.
VITE_ADMIN_USERNAME="admin"

# VITE_ADMIN_PASSWORD_HASH: The cryptographic SHA-256 hash value of the password.
# Passwords must not be stored in plain text.
# The onboarding wizard inside the app will calculate this hash for you!
VITE_ADMIN_PASSWORD_HASH="8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918"

# =========================
# CLOUD BACKEND (OPTIONAL)
# =========================

# VITE_SUPABASE_URL: The public project URL from your Supabase settings panel.
# Leave blank to fall back to the standalone high-fidelity LocalStorage database.
VITE_SUPABASE_URL=""

# VITE_SUPABASE_ANON_KEY: The client-side anonymous API Key from your Supabase settings panel.
VITE_SUPABASE_ANON_KEY=""
